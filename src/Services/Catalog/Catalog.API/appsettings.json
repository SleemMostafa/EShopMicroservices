{
  "ConnectionStrings": {
    "Database": "Server=localhost;Port=5432;Database=CatalogDb;User Id=postgres;Password=postgres;Include Error Detail=true"
  },
  "Jwt": {
    "Issuer": "EShop.Identity",
    "Audience": "EShop.Services",
    "Secret": "CHANGE_ME_DEV_SECRET_1234567890_32_CHARS_MIN",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "ClockSkewSeconds": 30
  },
  "Correlation": {
    "HeaderName": "X-Correlation-ID"
  },
  "Idempotency": {
    "Enabled": true,
    "ExpirationMinutes": 60
  },
  "Resilience": {
    "Http": {
      "TotalRequestTimeoutSeconds": 30,
      "AttemptTimeoutSeconds": 10,
      "Retry": {
        "MaxRetryAttempts": 3,
        "DelaySeconds": 1,
        "MaxDelaySeconds": 15,
        "UseJitter": true
      },
      "CircuitBreaker": {
        "FailureRatio": 0.5,
        "MinimumThroughput": 10,
        "SamplingDurationSeconds": 30,
        "BreakDurationSeconds": 30
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
