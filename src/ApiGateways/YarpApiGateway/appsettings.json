{
  "ReverseProxy": {
    "Routes": {
      "catalog-prefixed": {
        "ClusterId": "catalog",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/catalog-service/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/catalog-service"
          }
        ]
      },
      "catalog-create-product": {
        "ClusterId": "catalog",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/products-service",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/products"
          }
        ]
      },
      "catalog-update-product": {
        "ClusterId": "catalog",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/products-service",
          "Methods": [
            "PUT"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/products"
          }
        ]
      },
      "catalog-delete-product": {
        "ClusterId": "catalog",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/products-service/{**catch-all}",
          "Methods": [
            "DELETE"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/products/{**catch-all}"
          }
        ]
      },
      "catalog-service-products-root": {
        "ClusterId": "catalog",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/catalog-service/products",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/products"
          }
        ]
      },
      "catalog-service-products": {
        "ClusterId": "catalog",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/catalog-service/products/{**catch-all}",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/products/{**catch-all}"
          }
        ]
      },
      "catalog-products-root": {
        "ClusterId": "catalog",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/products-service",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/products"
          }
        ]
      },
      "catalog-products": {
        "ClusterId": "catalog",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/products-service/{**catch-all}",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/products/{**catch-all}"
          }
        ]
      },
      "basket": {
        "ClusterId": "basket",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/basket-service/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/basket/{**catch-all}"
          }
        ]
      },
      "basket-store": {
