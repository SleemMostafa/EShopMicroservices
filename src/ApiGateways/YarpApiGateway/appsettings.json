      "identity-revoke-refresh-token": {
        "ClusterId": "identity",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "auth-fixed-window",
        "Match": {
          "Path": "/identity-service/revoke-refresh-token",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
