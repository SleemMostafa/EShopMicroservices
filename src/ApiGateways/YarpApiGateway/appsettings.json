        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "gateway-sliding-window",
        "Match": {
          "Path": "/orders-service",
          "Methods": [
            "PUT"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/orders"
          }
        ]
      },
      "ordering-create-order": {
        "ClusterId": "ordering",
        "Order": -1,
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "checkout-fixed-window",
        "Match": {
          "Path": "/orders-service",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/orders"
          }
        ]
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": {
          "catalogApi": {
            "Address": "http://localhost:7000/"
          }
        }
      },
      "basket": {
        "Destinations": {
          "basketApi": {
            "Address": "http://localhost:7001/"
          }
        }
      },
      "identity": {
        "Destinations": {
          "identityApi": {
            "Address": "http://localhost:7003/"
          }
        }
      },
      "ordering": {
        "Destinations": {
          "orderingApi": {
            "Address": "http://localhost:7004/"
          }
        }
      }
    }
  },
  "Jwt": {
    "Issuer": "EShop.Identity",
    "Audience": "EShop.Services",
    "Secret": "",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "ClockSkewSeconds": 30
  },
  "RateLimiting": {
    "SlidingWindow": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    },
    "AuthFixedWindow": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "CheckoutFixedWindow": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Correlation": {
    "HeaderName": "X-Correlation-ID"
  },
  "Resilience": {
    "Http": {
      "TotalRequestTimeoutSeconds": 30,
      "AttemptTimeoutSeconds": 10,
      "Retry": {
        "MaxRetryAttempts": 3,
        "DelaySeconds": 1,
        "MaxDelaySeconds": 15,
        "UseJitter": true
      },
      "CircuitBreaker": {
        "FailureRatio": 0.5,
        "MinimumThroughput": 10,
        "SamplingDurationSeconds": 30,
        "BreakDurationSeconds": 30
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*"
}
