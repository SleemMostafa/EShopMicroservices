{
  "Jwt": {
    "Secret": "",
    "AccessTokenExpirationMinutes": 15,
    "ClockSkewSeconds": 30
  },
  "ReverseProxy": {
    "Clusters": {
      "catalog": {
        "Destinations": {
          "catalogApi": {
            "Address": "http://catalog.api:8080/"
          }
        }
      },
      "basket": {
        "Destinations": {
          "basketApi": {
            "Address": "http://basket.api:8080/"
          }
        }
      },
      "identity": {
        "Destinations": {
          "identityApi": {
            "Address": "http://identity.api:8080/"
          }
        }
      },
      "ordering": {
        "Destinations": {
          "orderingApi": {
            "Address": "http://ordering.api:8080/"
          }
        }
      }
    }
  },
  "RateLimiting": {
    "SlidingWindow": {
      "PermitLimit": 300,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    },
    "AuthFixedWindow": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "CheckoutFixedWindow": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*"
}
